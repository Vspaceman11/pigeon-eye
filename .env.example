# Convex (Next.js client)
CONVEX_URL=

# n8n (called from browser → must be NEXT_PUBLIC)
NEXT_PUBLIC_N8N_WEBHOOK_URL=

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

ISSUES_INGEST_SECRET=

# Convex site URL (for HTTP endpoints)
CONVEX_SITE_URL=

# ── Convex Dashboard → Settings → Environment Variables ──
# These are set in the Convex dashboard, NOT in .env.local:
#
# N8N_WEBHOOK_URL       — n8n webhook that receives {issue_id, image_url, ...}
# N8N_WEBHOOK_SECRET    — Bearer token sent to n8n (optional)
# WEBHOOK_SECRET        — Bearer token n8n sends back to /api/issues/analysis
# CONVEX_SITE_URL       — https://<deployment>.convex.site (for callback_url)
